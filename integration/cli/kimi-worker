#!/usr/bin/env bash
# Lean Kimi worker lane. Measured 2026-07-19: an empty --skills-dir removes the
# user skills index (83% of the child system prompt) and cuts uncached input
# 91% on the same oracle (data/benchmarks/kimi-lane-2026-07-19.md).
#
# Contract: one bounded task packet on stdin or as arguments; the worker's
# final message is the only stdout. Exit 75 (retryable per Kimi CLI docs) is
# retried up to KIMI_WORKER_RETRIES times; other codes pass through.
#
# Env:
#   KIMI_WORKER_SHARE_DIR  per-team state root (default: mktemp, discarded)
#   KIMI_WORKER_RETRIES    retries on exit 75 (default: 2)
#   KIMI_WORKER_MODEL      optional model alias for -m
#   KIMI_WORKER_EVIDENCE   optional file path; worker is told to write
#                          findings there and return only claim + path
#   KIMI_WORKER_USAGE_OUT  optional JSONL path; per-request usage from the
#                          session wire log is appended in the Anthropic
#                          field names agent-token-ledger reads
#                          (requires KIMI_WORKER_SHARE_DIR)
set -uo pipefail

retries="${KIMI_WORKER_RETRIES:-2}"
skills_dir="$(mktemp -d)"
trap 'rm -rf "$skills_dir"' EXIT

if [ -n "${KIMI_WORKER_SHARE_DIR:-}" ]; then
  export KIMI_SHARE_DIR="$KIMI_WORKER_SHARE_DIR"
  # A fresh share dir has no model/credentials; seed both from the default
  # root so isolation only separates sessions/accounting, not identity.
  default_root="${KIMI_WORKER_SEED_FROM:-$HOME/.kimi}"
  mkdir -p "$KIMI_SHARE_DIR"
  for item in config.toml kimi.json device_id credentials; do
    if [ ! -e "$KIMI_SHARE_DIR/$item" ] && [ -e "$default_root/$item" ]; then
      cp -R "$default_root/$item" "$KIMI_SHARE_DIR/$item"
    fi
  done
fi

prompt="${*:-$(cat)}"
if [ -n "${KIMI_WORKER_EVIDENCE:-}" ]; then
  prompt="$prompt
Write full findings to the file $KIMI_WORKER_EVIDENCE; your final message is only the one-line claim and that path."
fi

args=(--quiet -y --skills-dir "$skills_dir")
if [ -n "${KIMI_WORKER_MODEL:-}" ]; then
  args+=(-m "$KIMI_WORKER_MODEL")
fi

export_usage() {
  [ -n "${KIMI_WORKER_USAGE_OUT:-}" ] || return 0
  [ -n "${KIMI_WORKER_SHARE_DIR:-}" ] || return 0
  python3 - "$KIMI_WORKER_SHARE_DIR" "$KIMI_WORKER_USAGE_OUT" <<'PY' || true
import json, re, sys
from pathlib import Path

share, out = Path(sys.argv[1]), Path(sys.argv[2])
wires = sorted(share.glob("sessions/*/*/wire.jsonl"), key=lambda p: p.stat().st_mtime)
if not wires:
    sys.exit(0)
text = wires[-1].read_text(errors="replace")
total = {"input_tokens": 0, "cache_creation_input_tokens": 0,
         "cache_read_input_tokens": 0, "output_tokens": 0}
for raw in re.findall(r'"token_usage": (\{[^}]*\})', text):
    u = json.loads(raw)
    total["input_tokens"] += u.get("input_other", 0)
    total["cache_creation_input_tokens"] += u.get("input_cache_creation", 0)
    total["cache_read_input_tokens"] += u.get("input_cache_read", 0)
    total["output_tokens"] += u.get("output", 0)
if any(total.values()):
    # One summed record per run: the ledger reads a source's last usage
    # snapshot as cumulative, so per-request rows would undercount.
    with out.open("a") as handle:
        handle.write(json.dumps({"usage": total}) + "\n")
PY
}

attempt=0
while :; do
  kimi-cli "${args[@]}" -p "$prompt"
  code=$?
  if [ "$code" -ne 75 ] || [ "$attempt" -ge "$retries" ]; then
    export_usage
    exit "$code"
  fi
  attempt=$((attempt + 1))
  sleep $((attempt * 2))
done
